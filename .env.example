# ─── DocShare — Environment Variables ────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# ─── REQUIRED ────────────────────────────────────────────────────────────────

# Database connection string (MySQL-compatible).
# Works with MySQL 8, TiDB, PlanetScale, Railway MySQL, Amazon RDS.
# Example: mysql://user:password@host:3306/dbname
DATABASE_URL=mysql://user:password@localhost:3306/docshare

# JWT signing secret — must be ≥32 random bytes.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-secret

# ─── AUTH ─────────────────────────────────────────────────────────────────────

# Access control: comma-separated email domains allowed to sign in.
# Set to "*" for open signup (any email), or "example.com,partner.com" to restrict.
ALLOWED_EMAIL_DOMAINS=*

# Optional: comma-separated admin emails auto-granted "admin" role on first sign-in.
# Example: ADMIN_EMAILS=alice@example.com,bob@example.com
# Leave empty — manage roles through the Admin UI at /admin.
ADMIN_EMAILS=

# Optional: email address that is always treated as admin (the "owner" account).
# Usually the first user's email address.
OWNER_OPEN_ID=

# Optional: alias email mappings for merging accounts.
# Format: alias1@example.com=canonical@example.com,alias2@example.com=canonical@example.com
EMAIL_ALIASES=

# ─── OAUTH / SSO (optional) ──────────────────────────────────────────────────
# Only needed if you want OAuth SSO in addition to (or instead of) magic-link email auth.
# Set OAUTH_SERVER_URL to your OAuth provider's base URL and APP_ID to your app's client id.
# Leave empty to use magic-link email auth only.
APP_ID=
OAUTH_SERVER_URL=

# ─── EMAIL (magic-link delivery) ─────────────────────────────────────────────

# Resend API key — required to send magic-link emails.
# Get a free key at https://resend.com
# In dev: magic links are printed to console even without RESEND_API_KEY set.
RESEND_API_KEY=re_xxxxxxxxxxxx

# From address shown in outgoing emails.
# Must be a verified domain in your Resend account.
EMAIL_FROM=DocShare <noreply@yourdomain.com>

# App name shown in emails and UI.
APP_NAME=DocShare

# Public URL of your deployment — used in magic-link emails and OG share previews.
PUBLIC_BASE_URL=http://localhost:3000

# ─── STORAGE ─────────────────────────────────────────────────────────────────
# STORAGE_PROVIDER controls which backend stores uploaded files.
# Options: "proxy" (default), "s3", "local"

STORAGE_PROVIDER=proxy

# --- Proxy backend (STORAGE_PROVIDER=proxy) ---
# Uses an HTTP upload proxy.
# Required when STORAGE_PROVIDER=proxy (PROXY_API_URL + PROXY_API_KEY).
PROXY_API_URL=
PROXY_API_KEY=

# --- S3/R2/MinIO backend (STORAGE_PROVIDER=s3) ---
S3_BUCKET=
S3_REGION=us-east-1
# S3_ENDPOINT is required for R2/MinIO; leave empty for AWS S3
S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Local filesystem backend (STORAGE_PROVIDER=local, dev/test only) ---
STORAGE_LOCAL_DIR=./uploads

# ─── AI / LLM (optional — powers AI narration feature) ───────────────────────
# Any OpenAI-compatible API works: OpenAI, Together, Groq, Ollama, etc.

AI_API_BASE_URL=https://api.openai.com
AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
AI_MODEL=gpt-4o-mini

# ─── ANALYTICS (optional) ────────────────────────────────────────────────────
# Leave empty to disable Umami analytics.
UMAMI_SCRIPT_URL=
UMAMI_WEBSITE_ID=

# ─── FRONTEND (Vite — exposed to the browser, must be prefixed VITE_) ─────────
# These are read at build time by the client. Only set what you use.
#
# OAuth portal URL + app id for the optional SSO sign-in button.
# Leave empty if you only use magic-link email auth.
VITE_OAUTH_PORTAL_URL=
VITE_APP_ID=
#
# Umami analytics injected into index.html. Leave empty to disable.
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# ─── SERVER ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
